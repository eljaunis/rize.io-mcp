{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rize-io-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-16",
  "observability": {
    "enabled": true
  },
  "vars": {
    "OAUTH_AUTHORIZE_ROUTE": "/authorize",
    "OAUTH_CLIENT_REGISTRATION_ROUTE": "/register",
    "MCP_ROUTE": "/mcp",
    "HEALTH_ROUTE": "/health",
    "TOKEN_ROUTE": "/token"
  }
}
